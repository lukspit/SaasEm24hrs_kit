# ─────────────────────────────────────────
#  SaaS em 24h — Variáveis de Ambiente
#  Copie este arquivo para .env.local
#  NUNCA commite o .env.local
# ─────────────────────────────────────────

# ── Supabase ──────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxx...

# Apenas para server-side (webhooks, scripts) — NUNCA no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxx...

# ── Stripe ────────────────────────────────
# Encontre em: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx

# Encontre em: dashboard.stripe.com → Developers → Webhooks → seu endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# ── App ───────────────────────────────────
# URL da sua aplicação (sem barra no final)
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# ── IDs de Preço do Stripe ────────────────
# Encontre em: dashboard.stripe.com → Products → seu produto → ID do preço
STRIPE_PRICE_ID_MONTHLY=price_xxxxxxxxxx
